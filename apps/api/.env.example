# ============================================
# Lattice - API Environment Variables
# ============================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change_this_to_a_random_secret_key_minimum_32_chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- PostgreSQL ---
# Get from: local install, Railway, Render, or Neon
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lattice

# --- Redis ---
# Get from: local install or Redis Cloud (https://redis.com/try-free/)
REDIS_URL=redis://localhost:6379/0

# --- Neo4j (Graph Database) ---
# Get from: Neo4j AuraDB free tier (https://neo4j.com/cloud/platform/aura-graph-database/)
# Or run locally via Docker
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# --- Weaviate (Vector Database) ---
# Get from: Weaviate Cloud (https://weaviate.io/developers/wcs) or local Docker
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your_weaviate_api_key

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Anthropic ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Clerk (Auth) ---
# Get from: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# --- Observability ---
# Get from: https://sentry.io (create new project → FastAPI)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Langfuse for AI observability (https://langfuse.com)
LANGFUSE_SECRET_KEY=sk-lf-your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=pk-lf-your_langfuse_public_key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Integrations (optional) ---
# Google OAuth for Gmail/Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Slack
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token

# Crunchbase
CRUNCHBASE_API_KEY=your_crunchbase_api_key

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
